{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "辩论赛计时器",
  "version": "0.1.0",
  "identifier": "io.hanzn.dct",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "辩论赛计时器 - 配置",
        "width": 900,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "label": "main"
      },
      {
        "title": "辩论赛计时器 - 计时",
        "width": 1920,
        "height": 1080,
        "center": true,
        "label": "timer",
        "url": "timer.html",
        "visible": false,
        "fullscreen": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
